# ========================================
# PLANTILLA DE VARIABLES DE ENTORNO
# Copia este archivo como .env y ajusta los valores según tu configuración
# ========================================

# ========================================
# CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# ========================================

# Host donde se ejecuta PostgreSQL (localhost para desarrollo local)
DB_HOST="localhost"

# Puerto de conexión de PostgreSQL (por defecto 5432)
DB_PORT="5432"

# Usuario de la base de datos PostgreSQL
DB_USER="postgres"

# Contraseña del usuario de PostgreSQL
# ⚠️  IMPORTANTE: Cambia este valor por tu contraseña real
DB_PASSWORD="tu_password_aqui"

# Nombre de la base de datos a utilizar
DB_NAME="tesis_archivos"

# URL completa de conexión construida a partir de las variables anteriores
# Prisma utiliza esta URL para conectarse a PostgreSQL
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# ========================================
# CONFIGURACIÓN DEL SERVIDOR
# ========================================

# Puerto donde se ejecutará el servidor Express
PORT=3000

# ========================================
# INTEGRACIÓN CON N8N
# ========================================

# URL completa del webhook de n8n donde se enviarán las notificaciones
# cuando se suba un archivo al sistema
N8N_WEBHOOK_URL="http://localhost:5678/webhook/file_uploaded"

# ========================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ========================================

# Entorno de ejecución (development, production, test)
NODE_ENV="development"

# Nombre de la aplicación (usado en logs y mensajes)
APP_NAME="Sistema de Gestión de Archivos - Tesis"

# ========================================
# OPENAI / CHATGPT - RECOMENDACIONES PERSONALIZADAS
# ========================================

# Habilitar/deshabilitar generación de recomendaciones con ChatGPT
USE_CHATGPT_RECOMMENDATIONS="true"

# API Key de OpenAI (obtener en: https://platform.openai.com/api-keys)
OPENAI_API_KEY=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

# Modelo de OpenAI a utilizar
# RECOMENDADO: gpt-4o (profesional, preciso, alineado a RAG)
# Alternativas: gpt-4-turbo, gpt-4o-mini (más económico pero menos preciso)
OPENAI_MODEL="gpt-4o"

# Temperature (0.0 = determinístico, 1.0 = creativo)
# RECOMENDADO: 0.0 para máxima consistencia y alineación al RAG
OPENAI_TEMPERATURE="0.0"

# Máximo de tokens en respuesta (longitud de recomendaciones)
OPENAI_MAX_TOKENS="1500"

# Timeout para requests a OpenAI (en milisegundos)
CHATGPT_TIMEOUT="30000"